// FindTransactionsByDateRange simulates fetching data from a database.
func (m *MockTransactionRepository) FindTransactionsByDateRange(ctx context.Context, start, end time.Time) ([]model.Transaction, error) {
	var results []model.Transaction
	for _, t := range m.transactions {
		if !t.Date.Before(start) && !t.Date.After(end) {
			results = append(results, t)
		}
	}
	return results, nil
}
