package api

import (
	"log"
	"net/http"
	"time"

	"github.com/example/reporting/model"
	"github.com/example/reporting/service"
)

// ReportHandler handles HTTP requests for reports.
type ReportHandler struct {
	service service.ReportService
}

// NewReportHandler creates a new ReportHandler.
func NewReportHandler(s service.ReportService) *ReportHandler {
	return &ReportHandler{service: s}
}

// GetReport is the handler function for GET /api/reports.
// It parses query parameters for filtering and returns a report.
func (h *ReportHandler) GetReport(w http.ResponseWriter, r *http.Request) {
	// Default date range to the current month if not provided
	now := time.Now()
	defaultStart := time.Date(now.Year(), now.Month(), 1, 0, 0, 0, 0, time.UTC)
	defaultEnd := defaultStart.AddDate(0, 1, -1)

	// Parse date filters
	startDateStr := r.URL.Query().Get("start_date")
	endDateStr := r.URL.Query().Get("end_date")

	startDate, err := parseDate(startDateStr, defaultStart)
	if err != nil {
		respondWithError(w, http.StatusBadRequest, "Invalid start_date format. Use YYYY-MM-DD.")
		return
	}
	endDate, err := parseDate(endDateStr, defaultEnd)
	if err != nil {
		respondWithError(w, http.StatusBadRequest, "Invalid end_date format. Use YYYY-MM-DD.")
		return
	}

	// Parse multi-select filters
	categoryIDs, err := parseCommaSeparatedInts(r.URL.Query().Get("category_ids"))
	if err != nil {
		respondWithError(w, http.StatusBadRequest, "Invalid category_ids format. Must be comma-separated integers.")
		return
	}

	accountIDs, err := parseCommaSeparatedInts(r.URL.Query().Get("account_ids"))
	if err != nil {
		respondWithError(w, http.StatusBadRequest, "Invalid account_ids format. Must be comma-separated integers.")
		return
	}

	filter := model.ReportFilter{
		StartDate:   startDate,
		EndDate:     endDate,
		CategoryIDs: categoryIDs,
		AccountIDs:  accountIDs,
	}

	log.Printf("Generating report with filter: %+v", filter)
	report, err := h.service.GenerateReport(r.Context(), filter)
	if err != nil {
		log.Printf("Error generating report: %v", err)
		respondWithError(w, http.StatusInternalServerError, "Could not generate report")
		return
	}

	respondWithJSON(w, http.StatusOK, report)
}

// parseDate is a helper to parse date strings with a fallback default.
func parseDate(dateStr string, defaultValue time.Time) (time.Time, error) {
	if dateStr == "" {
		return defaultValue, nil
	}
	return time.Parse("2006-01-02", dateStr)
}
