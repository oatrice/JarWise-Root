package service

import (
	"context"
	"github.com/example/reporting/model"
	"github.com/example/reporting/storage"
)

// ReportService defines the interface for the report generation business logic.
type ReportService interface {
	GenerateReport(ctx context.Context, filter model.ReportFilter) (*model.Report, error)
}

// reportServiceImpl is the implementation of ReportService.
type reportServiceImpl struct {
	repo storage.TransactionRepository
}

// NewReportService creates a new instance of the report service.
func NewReportService(repo storage.TransactionRepository) ReportService {
	return &reportServiceImpl{repo: repo}
}

// GenerateReport creates a report based on the provided filters.
func (s *reportServiceImpl) GenerateReport(ctx context.Context, filter model.ReportFilter) (*model.Report, error) {
	// Fetch all transactions within the date range first.
	allTransactions, err := s.repo.FindTransactionsByDateRange(ctx, filter.StartDate, filter.EndDate)
	if err != nil {
		return nil, err
	}

	filteredTransactions := s.applyFilters(allTransactions, filter)

	report := &model.Report{
		FilterUsed:   filter,
		Transactions: filteredTransactions,
		TransactionCount: len(filteredTransactions),
	}

	// Calculate total amount from filtered transactions
	var total float64
	for _, t := range filteredTransactions {
		total += t.Amount
	}
	report.TotalAmount = total

	return report, nil
}

// applyFilters processes transactions against category and account filters.
func (s *reportServiceImpl) applyFilters(transactions []model.Transaction, filter model.ReportFilter) []model.Transaction {
	// If no filters are provided, return all transactions
	if len(filter.CategoryIDs) == 0 && len(filter.AccountIDs) == 0 {
		return transactions
	}

	// Create maps for quick lookups
	categoryFilter := make(map[int]bool)
	if len(filter.CategoryIDs) > 0 {
		for _, id := range filter.CategoryIDs {
			categoryFilter[id] = true
		}
	}

	accountFilter := make(map[int]bool)
	if len(filter.AccountIDs) > 0 {
		for _, id := range filter.AccountIDs {
			accountFilter[id] = true
		}
	}

	var result []model.Transaction
	for _, t := range transactions {
		// Logic for matching:
		// A transaction must match the category filter (if present) AND the account filter (if present).
		categoryMatch := len(categoryFilter) == 0 || categoryFilter[t.CategoryID]
		accountMatch := len(accountFilter) == 0 || accountFilter[t.AccountID]

		if categoryMatch && accountMatch {
			result = append(result, t)
		}
	}

	return result
}
