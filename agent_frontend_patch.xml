import React, { useState } from 'react';
import MultiSelectDropdown from './MultiSelectDropdown';
import './ReportFilters.css';

// Mock data - in a real application, this would come from an API
const mockCategories = [
  { id: 1, name: 'Groceries' },
  { id: 2, name: 'Utilities' },
  { id: 3, name: 'Rent' },
  { id: 4, name: 'Entertainment' },
  { id: 5, name: 'Transportation' },
  { id: 6, name: 'Health' },
  { id: 7, name: 'Dining Out' },
  { id: 8, name: 'Shopping' },
];

const mockAccounts = [
  { id: 101, name: 'Checking Account' },
  { id: 102, name: 'Savings Account' },
  { id: 103, name: 'Credit Card A' },
  { id: 104, name: 'Credit Card B' },
  { id: 105, name: 'Investment Portfolio' },
];


const ReportFilters = () => {
  const [selectedCategoryIds, setSelectedCategoryIds] = useState([]);
  const [selectedAccountIds, setSelectedAccountIds] = useState([]);

  const handleClearFilters = () => {
    setSelectedCategoryIds([]);
    setSelectedAccountIds([]);
  };

  const handleApplyFilters = () => {
    console.log("Applying filters:", {
      categories: selectedCategoryIds,
      accounts: selectedAccountIds,
    });
    // In a real application, this would trigger a data fetch or report generation
    alert(`Filters Applied!\nCategories: ${selectedCategoryIds.join(', ')}\nAccounts: ${selectedAccountIds.join(', ')}`);
  };

  return (
    <div className="report-filters-card">
      <h2 className="report-filters-title">Report Filters</h2>
      <div className="filters-container">
        <MultiSelectDropdown
          label="Categories"
          options={mockCategories}
          selectedIds={selectedCategoryIds}
          onChange={setSelectedCategoryIds}
        />
        <MultiSelectDropdown
          label="Accounts"
          options={mockAccounts}
          selectedIds={selectedAccountIds}
          onChange={setSelectedAccountIds}
        />
      </div>
      <div className="actions-container">
        <button className="filter-button secondary" onClick={handleClearFilters}>
          Clear Filters
        </button>
        <button className="filter-button primary" onClick={handleApplyFilters}>
          Apply Filters
        </button>
      </div>
    </div>
  );
};

export default ReportFilters;
